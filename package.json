{
  "name": "umusare-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Umusare public website, admin portal, and backend API workspace.",
  "scripts": {
    "dev:web": "npm --prefix frontend run dev",
    "dev:admin": "npm --prefix admin run dev",
    "dev:api": "npm --prefix server run dev",
    "build:web": "npm --prefix frontend run build",
    "build:admin": "npm --prefix admin run build",
    "build:api": "npm --prefix server run build",
    "build": "npm run build:web && npm run build:admin && npm run build:api"
  },
  "workspaces": [
    "frontend",
    "admin",
    "server"
  ],
  "dependencies": {
    "gsap": "^3.15.0",
    "lenis": "^1.3.23"
  }
}
